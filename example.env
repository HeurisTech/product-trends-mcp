# Product Trends MCP Environment Variables

# Required: Apify API token for scraping TikTok and Instagram
# You can get this from your Apify account
APIFY_API_TOKEN=your_apify_api_token_here

# Optional: Logging configuration
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR
DEBUG=false

# Optional: Default port for the server
# Note: This will be overridden by the --port command line argument if provided
FASTMCP_PORT=8000
FASTMCP_HOST=0.0.0.0 